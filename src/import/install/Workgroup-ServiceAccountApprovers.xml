<?xml version='1.0' encoding='UTF-8'?>
<!DOCTYPE sailpoint PUBLIC "sailpoint.dtd" "sailpoint.dtd">
<sailpoint>

  <!--
      Escalation / fallback approver workgroup for the Orphan Account
      Correlator plugin.

      The Workflow-OrphanCorrelationApproval workflow routes the manager
      approval work item to this workgroup whenever no line manager can be
      resolved for the matched identity, or the resolved manager is the
      requesting administrator (self-approval is never allowed).

      IMPORTANT: this workgroup is imported EMPTY. Administrators must add
      members (Setup > Groups > Workgroups > ServiceAccount-Approvers) or
      approvals that hit the fallback path will sit unowned in the group
      until members are assigned. If the workgroup is deleted, the workflow
      fails closed and routes those approvals to spadmin.
  -->
  <Identity name="ServiceAccount-Approvers" workgroup="true">
    <Description>
      Escalation/fallback approver group for the Orphan Account Correlator
      plugin. Receives orphan-correlation approval work items when the
      matched identity has no resolvable manager, or when the manager is the
      requesting administrator (to prevent self-approval). Administrators
      should add members to this workgroup after plugin installation.
    </Description>
  </Identity>

</sailpoint>
